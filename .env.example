# =============================================================================
# Scraper API — Environment variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Environment variables take priority over configs/config.yaml.
# =============================================================================

# API key required for all authenticated endpoints.
SCRAPER_API_KEY=change-me

# Config file path (mounted volume in container).
CONFIG_PATH=/config/config.yaml

# Cache database path (persistent volume).
CACHE_SQLITE_PATH=data/scraper-cache.db

# Debug output directory.
DEBUG_DIR=debug

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
