# =============================================================================
# Scraper API — Environment variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Environment variables take priority over configs/config.yaml.
# =============================================================================

# API key required for all authenticated endpoints.
SCRAPER_API_KEY=change-me

# Additional API keys for named profiles (see ``auth.api_keys`` in config.yaml).
SCRAPER_API_KEY_DEBUG=change-me-debug

# Server port (overrides configs/config.yaml server.port).
# SCRAPER_SERVER_PORT=9090

# Config file path (mounted volume in container).
CONFIG_PATH=/config/config.yaml

# Cache database path (persistent volume in container, relative for local use).
SCRAPER_CACHE_SQLITE_PATH=data/scraper-cache.db

# Debug output directory.
SCRAPER_DEBUG_DIR=debug

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
